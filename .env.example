# 数据模式: jnb(走Tushare API) 或 websearch(走网络搜索)
DATA_MODE=jnb

# Tushare API 配置
# 注意：以下两项仅在 DATA_MODE=jnb 且未使用 Indevs 时必须填写
TUSHARE_TOKEN=你...n
# Tushare 中转 API 地址（必填，如果使用 websearch 模式则忽略）
# 格式: http://your-proxy-server.com
# 示例: https://tt.xiaodefa.cn
TUSHARE_API_URL=
# TUSHARE_VERIFY_TOKEN_URL=*** 可选，实时行情验证地址

# Tushare Bridge 配置（可选，用于数据降级和回测验证）
# TUSHARE_BRIDGE_HOST=localhost
# TUSHARE_BRIDGE_PORT=8866
# TUSHARE_BRIDGE_TIMEOUT=30
# TUSHARE_BRIDGE_ENABLED=true

# 限流配置（可选）
# TUSHARE_RPM=120  # 每分钟请求数

# Indevs Tushare Replay API 配置（可选）
# 文档: https://ai-tool.indevs.in/quant/tushare-pro-catalog/
# 如果配置了 INDEVS_API_KEY，数据同步会优先走该数据源
# INDEVS_API_KEY=your_api_key
# INDEVS_API_URL=https://ai-tool.indevs.in/tushare/pro

# 数据库配置
DATA_DIR=data
DB_PATH=data/stock_data.db

# LLM 配置（意图识别后的回答生成，可选）
# 未配置 LLM_API_KEY 时不生成回答，仅显示意图识别结果
# 支持 OpenAI 兼容格式的 API
LLM_API_KEY=*** LLM_...n
# LLM_BASE_URL=https://api.openai.com/v1  # LLM API 地址
# LLM_MODEL=gpt-4o-mini  # LLM 模型名称
# ANTHROPIC_API_KEY=*** 可选，Anthropic Claude API

# 向量知识库配置（可选，默认关闭）
# KB_ENABLED=true  # 取消注释以启用
# KB_API_URL=http://localhost:8000

# 主动推送配置（可选，自选股触发预警时会推送到该飞书 webhook）
# 示例：https://open.feishu.cn/open-apis/bot/v2/hook/xxxx
IM_PUSH_WEBHOOK=

# 缓存配置（可选）
# COMMENTARY_CACHE_TTL=3600  # 点评缓存 TTL（秒）
# SIMULATION_NARRATE_CACHE_TTL=3600  # 叙事缓存 TTL（秒）

# 自定义 .env 文件路径（可选）
# ZETTARANC_ENV=/path/to/custom/.env
